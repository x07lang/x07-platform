{
  "clang": {
    "cc": null,
    "cflags": [
      "--target=wasm32-wasi",
      "-O3",
      "-DNDEBUG",
      "-std=c11",
      "-ffunction-sections",
      "-fdata-sections",
      "-fvisibility=hidden"
    ]
  },
  "codegen_backend": "native_x07_wasm_v1",
  "defaults": {
    "arena_cap_bytes": 33554432,
    "max_output_bytes": 2097152
  },
  "id": "wasm_web_ui_release",
  "runtime": {
    "instance_allocator": "on_demand",
    "max_fuel": 200000000,
    "max_memory_bytes": 67108864,
    "max_table_elements": 131072,
    "max_wasm_stack_bytes": 1048576
  },
  "schema_version": "x07.wasm.profile@0.3.0",
  "target": {
    "entry_export": "x07_solve_v2",
    "triple": "wasm32-wasi",
    "wasm_c_abi": "basic_c_abi@1"
  },
  "v": 1,
  "wasm_ld": {
    "ldflags": [
      "--no-entry",
      "--stack-first",
      "-z",
      "stack-size=1048576",
      "--export=x07_solve_v2",
      "--export=__heap_base",
      "--export=__data_end",
      "--export-memory=memory",
      "--initial-memory=67108864",
      "--no-growable-memory",
      "--strip-debug",
      "--compress-relocations"
    ],
    "linker": null
  },
  "x07_build": {
    "emit_c_header": true,
    "freestanding": true
  }
}
