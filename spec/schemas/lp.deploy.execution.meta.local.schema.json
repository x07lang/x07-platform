{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/lp.deploy.execution.meta.local.schema.json",
  "title": "lp.deploy.execution.meta.local@0.1.0",
  "description": "Companion schema for local deployment execution metadata.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "target", "routing", "outcome"],
  "properties": {
    "schema_version": { "const": "lp.deploy.execution.meta.local@0.1.0" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app_id", "environment"],
      "properties": {
        "app_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "environment": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": true,
      "required": ["candidate_weight_pct"],
      "properties": {
        "candidate_weight_pct": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "outcome": {
      "type": "string",
      "enum": ["unknown", "promoted", "rolled_back", "aborted", "failed"]
    },
    "public_listener": { "type": "string", "maxLength": 2048 },
    "latest_decision_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "updated_unix_ms": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "revisions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stable": { "$ref": "#/$defs/digest_ref" },
        "candidate": { "$ref": "#/$defs/digest_ref" }
      }
    },
    "decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/decision_summary" },
      "default": []
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact_summary" },
      "default": []
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "digest_ref": {
      "type": "object",
      "additionalProperties": true,
      "required": ["sha256", "bytes_len"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "type": "integer", "minimum": 0 }
      }
    },
    "artifact_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["role", "digest"],
      "properties": {
        "role": { "type": "string", "minLength": 1, "maxLength": 128 },
        "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
        "digest": { "$ref": "#/$defs/digest_ref" },
        "media_type": { "type": "string", "minLength": 1, "maxLength": 256 },
        "logical_name": { "type": "string", "maxLength": 256 },
        "store_uri": { "type": "string", "maxLength": 2048 }
      }
    },
    "decision_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["decision_id", "kind", "outcome", "record"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
        "outcome": { "type": "string", "enum": ["allow", "deny", "error"] },
        "record": { "$ref": "#/$defs/artifact_summary" }
      }
    }
  }
}
