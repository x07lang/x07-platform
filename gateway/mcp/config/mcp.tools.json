{
  "schema_version": "x07.mcp.tools_manifest@0.2.0",
  "tools": [
    {
      "name": "lp.change.new",
      "description": "Create a deterministic lp.change_request artifact.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["app_id", "env", "intent"],
        "properties": {
          "app_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "env": { "type": "string", "minLength": 1, "maxLength": 64 },
          "intent": { "type": "string", "minLength": 1, "maxLength": 64 },
          "out": { "type": "string", "minLength": 1, "maxLength": 1024 },
          "state_dir": { "type": "string", "minLength": 1, "maxLength": 1024 },
          "now_unix_ms": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32,
            "pattern": "^[0-9]+$"
          }
        }
      },
      "x07": {
        "impl": "mcp.user.call_tool_v1",
        "limits_profile": "mcp_tool_standard_v1",
        "sandbox": {
          "fs": { "read_roots": ["."], "write_roots": ["out"] },
          "net": { "allow_dns": false, "allow_hosts": [] },
          "env": { "allow_keys": ["X07LP_STATE_DIR"] }
        },
        "auth": { "required_scopes": ["lp.change.write"] }
      }
    },
    {
      "name": "lp.change.validate",
      "description": "Validate a lp.change_request instance JSON.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["in"],
        "properties": {
          "in": { "type": "string", "minLength": 1, "maxLength": 1024 },
          "state_dir": { "type": "string", "minLength": 1, "maxLength": 1024 },
          "now_unix_ms": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32,
            "pattern": "^[0-9]+$"
          }
        }
      },
      "x07": {
        "impl": "mcp.user.call_tool_v1",
        "limits_profile": "mcp_tool_standard_v1",
        "sandbox": {
          "fs": { "read_roots": ["."], "write_roots": [] },
          "net": { "allow_dns": false, "allow_hosts": [] },
          "env": { "allow_keys": [] }
        },
        "auth": { "required_scopes": ["lp.change.read"] }
      }
    },
