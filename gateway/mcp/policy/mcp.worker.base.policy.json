{
  "schema_version": "x07.run-os-policy@0.1.0",
  "policy_id": "mcp.worker.base",
  "notes": "Base policy for MCP tool workers. No fs/net/env by default. Allows bounded sleep for backoff.",
  "limits": {
    "cpu_ms": 300000,
    "wall_ms": 300000,
    "mem_bytes": 1073741824,
    "fds": 64,
    "procs": 16,
    "core_dumps": false
  },
  "fs": {
    "enabled": true,
    "read_roots": [],
    "write_roots": [],
    "deny_hidden": true,
    "allow_symlinks": false,
    "allow_mkdir": true,
    "allow_remove": true,
    "allow_rename": true,
    "allow_walk": true,
    "allow_glob": true,
    "max_read_bytes": 33554432,
    "max_write_bytes": 33554432,
    "max_entries": 20000,
    "max_depth": 128
  },
  "net": {
    "enabled": false,
    "allow_dns": false,
    "allow_tcp": false,
    "allow_udp": false,
    "allow_hosts": []
  },
  "env": { "enabled": true, "allow_keys": ["PATH", "HOME", "X07LP_STATE_DIR"], "deny_keys": [] },
  "time": {
    "enabled": true,
    "allow_monotonic": true,
    "allow_wall_clock": true,
    "allow_sleep": true,
    "max_sleep_ms": 5000,
    "allow_local_tzid": false
  },
  "language": { "allow_unsafe": true, "allow_ffi": true },
  "threads": { "enabled": true, "max_workers": 0, "max_blocking": 4, "max_queue": 1024 },
  "process": {
    "enabled": true,
    "allow_spawn": true,
    "max_live": 4,
    "max_spawns": 32,
    "allow_exec": true,
    "allow_exit": true,
    "allow_execs": ["/usr/bin/env"],
    "allow_exec_prefixes": ["/Users/", "/home/", "/opt/homebrew/bin/", "/usr/local/bin/"],
    "allow_args_regex_lite": [],
    "allow_env_keys": ["PATH", "HOME"],
    "max_exe_bytes": 4096,
    "max_args": 64,
    "max_arg_bytes": 4096,
    "max_env": 64,
    "max_env_key_bytes": 256,
    "max_env_val_bytes": 4096,
    "max_runtime_ms": 300000,
    "max_stdout_bytes": 262144,
    "max_stderr_bytes": 262144,
    "max_total_bytes": 524288,
    "max_stdin_bytes": 16384,
    "kill_on_drop": true,
    "kill_tree": true,
    "allow_cwd": true,
    "allow_cwd_roots": [".", "/Users/", "/home/", "/tmp/", "/private/tmp/", "/var/folders/"]
  }
}
